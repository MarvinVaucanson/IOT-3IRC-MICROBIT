<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121416"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#B3121416"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="20dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="signal-icon"
                android:src="@drawable/ic_signal"
                app:tint="#B0C6FF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.1"
                android:paddingLeft="10dp"
                android:text="CENTRE_DE_COMMANDE_IOT"
                android:textColor="#B0C6FF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="radio-icon"
                android:src="@drawable/ic_radio"
                app:tint="#B0C6FF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TITRE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:fontFamily="@font/space_grotesk"
                android:gravity="center"
                android:text="SensorCommand"
                android:textColor="#E2E2E5"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/space_grotesk"
                android:gravity="center"
                android:text="Sélection du Serveur"
                android:textColor="#B0C6FF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:text="Sélectionnez un serveur pour commencer à surveiller les données de l'objet associé."
                android:textColor="#8888AA"
                android:textSize="14sp" />

            <!-- CARD: ADRESSE DU SERVEUR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.1"
                android:text="ADRESSE DU SERVEUR"
                android:textColor="#B0C6FF"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/editServerAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:background="@null"
                android:fontFamily="@font/inter"
                android:hint="IP du serveur"
                android:paddingBottom="8dp"
                android:textColor="#E2E2E5"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="24dp"
                android:background="#333355" />

            <!-- CARTE: PROTOCOLE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1A1C1E"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter"
                            android:letterSpacing="0.1"
                            android:text="PROTOCOLE RÉSEAU"
                            android:textColor="#8D909D"
                            android:textSize="11sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="lock-icon"
                            android:src="@drawable/ic_lock"
                            app:tint="#8888AA" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:fontFamily="@font/space_grotesk"
                            android:text="UDP"
                            android:textColor="#E2E2E5"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#1E1E3A"
                            android:letterSpacing="0.1"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="VERROUILLÉ"
                            android:textColor="#8D909D"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARTE: PORT -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1A1C1E"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#00D4FF" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/inter"
                            android:letterSpacing="0.1"
                            android:text="NUMÉRO DE PORT"
                            android:textColor="#8D909D"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/editPort"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="8080"
                            android:background="@null"
                            android:fontFamily="@font/space_grotesk"
                            android:hint="Port du serveur"
                            android:inputType="number"
                            android:textColor="#00D4FF"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARTE: LATENCE + CHIFFREMENT -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="#12122A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1A1C1E"
                    android:orientation="horizontal">

                    <!-- Latence -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/inter"
                            android:letterSpacing="0.1"
                            android:text="CIBLE DE LATENCE"
                            android:textColor="#8D909D"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/space_grotesk"
                            android:text="&lt; 12ms"
                            android:textColor="#B0C6FF"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#1E1E3A" />

                    <!-- Chiffrement -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/inter"
                            android:letterSpacing="0.1"
                            android:text="CHIFFREMENT"
                            android:textColor="#8D909D"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/space_grotesk"
                            android:text="AES-256"
                            android:textColor="#B0C6FF"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BOUTON SE CONNECTER -->
            <Button
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#B0C6FF"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.1"
                android:text="SE CONNECTER &gt;"
                android:textColor="#002D6F"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>

</ScrollView>