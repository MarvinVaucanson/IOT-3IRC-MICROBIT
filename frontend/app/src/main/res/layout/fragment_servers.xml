<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#121416"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#121416"
    >
        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp"
            android:background="#B3121416"
        >

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_signal"
                android:tint="#B0C6FF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="CENTRE_DE_COMMANDE_IOT"
                android:textColor="#B0C6FF"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="monospace" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_radio"
                android:tint="#B0C6FF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            >

            <!-- TITRE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Duke"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sélection du Serveur"
                android:textColor="#B0C6FF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sélectionnez un serveur pour commencer à surveiller les données de l'objet associé."
                android:textColor="#8888AA"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="32dp" />

            <!-- CARTE: ADRESSE DU SERVEUR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADRESSE DU SERVEUR"
                android:textColor="#B0C6FF"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/editServerAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="192.168.1.100"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:background="@null"
                android:paddingBottom="8dp"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333355"
                android:layout_marginBottom="24dp" />

            <!-- CARTE: PROTOCOLE (verrouillé) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1A1C1E"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="VERROUILLÉ"
                            android:textColor="#8888AA"
                            android:textSize="11sp"
                            android:letterSpacing="0.1" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_lock"
                            android:tint="#8888AA" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UDP"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="italic"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VERROUILLÉ"
                            android:textColor="#8888AA"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:background="#1E1E3A"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARTE: PORT -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#12122A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="#00D4FF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NUMÉRO DE PORT"
                        android:textColor="#8888AA"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/editPort"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8080"
                        android:textColor="#00D4FF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:background="@null"
                        android:inputType="number" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARTE: LATENCE + CHIFFREMENT -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="#12122A"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Latence -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CIBLE DE LATENCE"
                            android:textColor="#8888AA"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&lt; 12ms"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#1E1E3A" />

                    <!-- Chiffrement -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CHIFFREMENT"
                            android:textColor="#8888AA"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AES-256"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BOUTON SE CONNECTER -->
            <Button
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SE CONNECTER  ›"
                android:textColor="#0D0D1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:backgroundTint="#7DD4FC"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </LinearLayout>

</ScrollView>