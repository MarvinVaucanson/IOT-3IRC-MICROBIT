<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121416"
    android:orientation="vertical">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B3121416"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:clickable="true"
            android:contentDescription="back"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@drawable/ic_signal"
            app:tint="#B0C6FF" />

        <TextView
            android:id="@+id/textViewDeviceTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/space_grotesk"
            android:letterSpacing="0.1"
            android:textColor="#B0C6FF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="radio-icon"
            android:src="@drawable/ic_radio"
            app:tint="#B0C6FF" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/space_grotesk"
            android:letterSpacing="0.1"
            android:text="CAPTEURS ACTIFS"
            android:textColor="#00DAF3"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewDeviceSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/space_grotesk"
            android:textColor="#E2E2E5"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/inter"
            android:lineSpacingMultiplier="1.4"
            android:text="Maintenez et faites glisser pour réorganiser l'ordre d'affichage sur l'écran OLED."
            android:textColor="#8888AA"
            android:textSize="13sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewDeviceSensors"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/textViewCurrentOrder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/space_grotesk"
                android:gravity="center"
                android:letterSpacing="0.15"
                android:textColor="#8888AA"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnSendOrder"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#B0C6FF"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.1"
                android:text="ENVOYER L'ORDRE D'AFFICHAGE >"
                android:textColor="#002D6F"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
